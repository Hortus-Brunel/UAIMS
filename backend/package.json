{
  "name": "uaims-backend",
  "version": "1.0.0",
  "description": "UAIMS - University Announcement & Information Management System API",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node prisma/seed.js",
    "db:push": "npx prisma db push",
    "db:reset": "npx prisma db push --force-reset && node prisma/seed.js",
    "generate": "npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "6.x",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "6.x"
  },
  "keywords": ["uaims", "university", "announcement", "management"],
  "author": "UAIMS Team",
  "license": "ISC"
}
